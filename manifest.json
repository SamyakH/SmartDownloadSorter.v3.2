{
  "manifest_version": 3,
  "name": "Smart Download Sorter v3",
  "version": "3.2",
  "description": "Organizes downloads into Domain/Date/FileType folders with logs and notifications.",
  "permissions": [
    "downloads",
    "tabs",
    "storage",
    "notifications"
  ],
  "action": {
    "default_popup": "options.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content.js"]
    }
  ],
  "options_page": "options.html",
  "icons": {
    "48": "icon.png"
  }
}
